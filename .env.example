# ─── Infrastructure ──────────────────────────────────────────────
NODE_ENV=development
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Per-service Database URLs (each owns its own PostgreSQL schema) ──────────
AUTH_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/baaz?schema=auth
SELLER_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/baaz?schema=seller
CATALOG_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/baaz?schema=catalog
ORDER_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/baaz?schema=order
PAYMENT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/baaz?schema=payment
LOGISTICS_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/baaz?schema=logistics
NOTIFICATION_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/baaz?schema=notification

# ─── API Gateway ─────────────────────────────────────────────────
API_GATEWAY_PORT=3000
JWT_SECRET=supersecretchangeme
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000,http://localhost:4000

# ─── Service TCP Ports ────────────────────────────────────────────
AUTH_SERVICE_TCP_PORT=3001
SELLER_SERVICE_TCP_PORT=3002
CATALOG_SERVICE_TCP_PORT=3003
ORDER_SERVICE_TCP_PORT=3004
PAYMENT_SERVICE_TCP_PORT=3005
LOGISTICS_SERVICE_TCP_PORT=3006
NOTIFICATION_SERVICE_TCP_PORT=3007
