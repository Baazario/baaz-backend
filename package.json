{
  "name": "baaz-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "build:all": "nest build api-gateway && nest build auth-service && nest build seller-service && nest build catalog-service && nest build order-service && nest build payment-service && nest build logistics-service && nest build notification-service",
    "start:api-gateway": "nest start api-gateway --watch",
    "start:auth-service": "nest start auth-service --watch",
    "start:seller-service": "nest start seller-service --watch",
    "start:catalog-service": "nest start catalog-service --watch",
    "start:order-service": "nest start order-service --watch",
    "start:payment-service": "nest start payment-service --watch",
    "start:logistics-service": "nest start logistics-service --watch",
    "start:notification-service": "nest start notification-service --watch",
    "prisma:generate:auth-service": "prisma generate --schema=apps/auth-service/prisma/schema.prisma",
    "prisma:generate:seller-service": "prisma generate --schema=apps/seller-service/prisma/schema.prisma",
    "prisma:generate:catalog-service": "prisma generate --schema=apps/catalog-service/prisma/schema.prisma",
    "prisma:generate:order-service": "prisma generate --schema=apps/order-service/prisma/schema.prisma",
    "prisma:generate:payment-service": "prisma generate --schema=apps/payment-service/prisma/schema.prisma",
    "prisma:generate:logistics-service": "prisma generate --schema=apps/logistics-service/prisma/schema.prisma",
    "prisma:generate:notification-service": "prisma generate --schema=apps/notification-service/prisma/schema.prisma",
    "prisma:migrate:auth-service": "prisma migrate dev --schema=apps/auth-service/prisma/schema.prisma",
    "prisma:migrate:seller-service": "prisma migrate dev --schema=apps/seller-service/prisma/schema.prisma",
    "prisma:migrate:catalog-service": "prisma migrate dev --schema=apps/catalog-service/prisma/schema.prisma",
    "prisma:migrate:order-service": "prisma migrate dev --schema=apps/order-service/prisma/schema.prisma",
    "prisma:migrate:payment-service": "prisma migrate dev --schema=apps/payment-service/prisma/schema.prisma",
    "prisma:migrate:logistics-service": "prisma migrate dev --schema=apps/logistics-service/prisma/schema.prisma",
    "prisma:migrate:notification-service": "prisma migrate dev --schema=apps/notification-service/prisma/schema.prisma",
    "lint": "eslint \"{src,apps,libs}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/microservices": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/terminus": "^10.0.0",
    "@nestjs/throttler": "^5.0.0",
    "@prisma/client": "^5.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "ioredis": "^5.0.0",
    "joi": "^17.0.0",
    "nestjs-pino": "^4.0.0",
    "pino-http": "^9.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "pino-pretty": "^10.0.0",
    "prettier": "^3.0.0",
    "prisma": "^5.0.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": { "^.+\\.(t|j)s$": "ts-jest" },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "./coverage",
    "coverageThreshold": {
      "global": { "lines": 70, "functions": 70, "branches": 70, "statements": 70 }
    },
    "testEnvironment": "node",
    "roots": ["<rootDir>/apps/", "<rootDir>/libs/"],
    "moduleNameMapper": {
      "^@baaz/common(|/.*)$": "<rootDir>/libs/common/src/$1"
    }
  }
}
