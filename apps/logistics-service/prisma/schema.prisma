generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("LOGISTICS_DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ShipmentStatus {
  PENDING           // order confirmed, not yet picked up
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED_DELIVERY
  RETURNED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Shipment {
  id             String         @id @default(uuid())
  orderId        String         @unique  // references order-service Order.id
  trackingNumber String?        @unique
  carrier        String?        // "Delhivery", "BlueDart", etc.
  status         ShipmentStatus @default(PENDING)
  estimatedAt    DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  events TrackingEvent[]

  @@index([orderId])
  @@map("shipments")
}

model TrackingEvent {
  id          String   @id @default(uuid())
  shipmentId  String
  status      String   // raw status string from the carrier API
  description String
  location    String?
  occurredAt  DateTime
  createdAt   DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@map("tracking_events")
}
